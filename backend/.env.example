# ─────────────────────────────────────────────────────────────────────────────
# NigerianEmbassy Backend — .env
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:8081,https://your-app-domain.com

# Database — get this from Railway/Render/Supabase
DATABASE_URL="postgresql://postgres:password@localhost:5432/nigerian_embassy?schema=public"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_64_CHAR_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# Twilio SMS (Distress Call fallback)
# Sign up at twilio.com — free trial gives $15 credit
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Embassy Duty Officer Numbers
DUTY_OFFICER_JORDAN=+962777770001
DUTY_OFFICER_IRAQ=+962777770002

# Firebase (Push Notifications)
# Create project at console.firebase.google.com
# Go to Project Settings > Service Accounts > Generate New Private Key
FIREBASE_PROJECT_ID=nigerian-embassy-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@nigerian-embassy-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# SendGrid (Email)
# Sign up at sendgrid.com — free tier: 100 emails/day
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@nigerianembassy-jo.gov.ng

# Anthropic (AI Chatbot)
# Get key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Open Exchange Rates (Currency)
# Sign up at openexchangerates.org — free: 1000 requests/month
OPEN_EXCHANGE_RATES_APP_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenWeatherMap (Weather)
# Sign up at openweathermap.org — free: 1000 calls/day
OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS S3 (Document Storage) — optional, can add later
# AWS_REGION=me-south-1
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_S3_BUCKET=nigerian-embassy-documents
